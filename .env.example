# Local server settings
HOST=127.0.0.1
PORT=5000

# Keep true for local webcam detection. Set false on cloud platforms without a webcam.
CAMERA_ENABLED=true

# Optional path overrides. Defaults already point to these files.
SIGN_MODEL_PATH=backend/model/sign_model.pkl
MODEL_METADATA_PATH=backend/model/metadata.json
HAND_LANDMARKER_PATH=backend/hand_landmarker.task
FRONTEND_FILE=frontend/index.html
FRONTEND_ASSETS=frontend/assets
